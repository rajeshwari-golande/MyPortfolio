# Production environment — copy to .env on your server
# cp .env.production.example .env

# Public URL (IP or domain, no trailing slash)
# Examples:
#   http://150.136.xxx.xxx
#   https://rajeshwari.dev
PUBLIC_URL=http://YOUR_VM_PUBLIC_IP

# Frontend build-time API URL (must match PUBLIC_URL)
NEXT_PUBLIC_API_URL=http://YOUR_VM_PUBLIC_IP

# Database (change password before deploying!)
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=portfolio

# Backend
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGINS=http://YOUR_VM_PUBLIC_IP

# Caddy — use :80 for IP-only, or your domain for free HTTPS
SITE_ADDRESS=:80
ACME_EMAIL=your@email.com
