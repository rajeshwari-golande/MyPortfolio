# Split deploy — Vercel + Neon + Render (no credit card required)
# Copy to .env on your machine for reference only — NEVER commit real values.

# ── Vercel (frontend) ─────────────────────────────────────────────
# Set in Vercel Dashboard → Project → Settings → Environment Variables
NEXT_PUBLIC_API_URL=https://YOUR-RENDER-SERVICE.onrender.com

# ── Neon (PostgreSQL) ─────────────────────────────────────────────
# Copy connection string from Neon Dashboard → Connection Details
# Use the "Pooled" connection string with sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── Render (backend) ──────────────────────────────────────────────
# Set in Render Dashboard → Service → Environment
GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGINS=https://YOUR-VERCEL-APP.vercel.app

# Contact form email (pick ONE provider)
CONTACT_TO_EMAIL=you@example.com
# Option A — Resend (https://resend.com) free tier
RESEND_API_KEY=re_xxxxxxxx
# Option B — Web3Forms (https://web3forms.com) free access key
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key


# ── Optional: custom domain ───────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com
